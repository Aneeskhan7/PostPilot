{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(curl -I *)",
      "Bash(curl https://your-backend.railway.app/health)",
      "Read(**)",
      "Write(backend/src/**)",
      "Write(frontend/src/**)",
      "Write(backend/src/db/schema.sql)",
      "Write(.github/workflows/**)"
    ],
    "deny": [
      "Bash(curl -X POST *)",
      "Bash(curl -X DELETE *)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Write(.env*)",
      "Write(backend/.env)",
      "Write(frontend/.env)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[PostPilot] Running: $CLAUDE_TOOL_INPUT'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[PostPilot] ✅ File written: $CLAUDE_FILE_PATH'"
          }
        ]
      }
    ]
  },
  "env": {
    "POSTPILOT_ENV": "development"
  }
}
