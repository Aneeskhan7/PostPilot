# ── Mode ──────────────────────────────────────────────────────────────────────
# ollama = 100% local, free, unlimited (Ollama must be running)
# cloud  = Qwen DashScope API + Kimi API (needs API keys below)
AGENT_MODE=ollama

# ── Ollama settings (only used when AGENT_MODE=ollama) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# Model names — change to smaller sizes if you have low VRAM:
#   32b models: need ~20GB VRAM or ~32GB RAM (CPU fallback, slow)
#   14b models: need ~10GB VRAM or ~16GB RAM
#    7b models: need  ~5GB VRAM or  ~8GB RAM (fastest, lower quality)

OLLAMA_PLANNING_MODEL=qwq:32b               # Manager + Team Lead (reasoning)
OLLAMA_CODER_MODEL=qwen2.5-coder:32b        # All 5 specialists (coding)
OLLAMA_ANALYST_MODEL=qwen2.5:32b            # Security Auditor (large context)

# ── Cloud API keys (only used when AGENT_MODE=cloud) ─────────────────────────
# Qwen / Alibaba DashScope → https://dashscope.aliyun.com/
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kimi / Moonshot → https://platform.moonshot.cn/
# NOTE: Kimi has NO local version. In ollama mode, qwen2.5:32b is used instead.
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Project root ──────────────────────────────────────────────────────────────
PROJECT_ROOT=..
